# ============================================================
# AGENTE DE CONSULTA — Variables de Entorno
# Copiá este archivo como .env y completá los valores
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- PostgreSQL ---
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_db

# --- Google Sheets ---
# Cómo obtener las credenciales:
#   1. Ir a console.cloud.google.com → IAM → Cuentas de servicio → Crear cuenta
#   2. Crear una clave JSON y guardarla en credentials/
#   3. Habilitar "Google Sheets API" en APIs y Servicios → Biblioteca
#   4. Compartir cada spreadsheet con el email de la cuenta de servicio
#      (el email está dentro del JSON, campo "client_email")
#
# Si esta variable no está definida o el archivo no existe,
# el agente arranca igual pero sin las herramientas de Sheets.
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json
